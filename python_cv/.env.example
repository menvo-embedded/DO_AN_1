# Runtime config example for python_cv.
# Copy this file to .env in this folder and replace placeholders with local values.
# Never commit .env because it may contain RTSP, MQTT, or network secrets.

# ============================================================
# Current demo mode
# ============================================================
ENABLE_MQTT=false
ENABLE_INSIGHTFACE=true
ENABLE_ZONE1=false
ENABLE_ZONE2=true

# ============================================================
# Camera
# ============================================================
CAM_ZONE1_INDEX=0
CAM_ZONE2_TYPE=webcam
CAM_ZONE2_INDEX=0
CAM_ZONE2_RTSP=rtsp://username:password@camera-ip:554/cam/realmonitor?channel=1&subtype=1

# ============================================================
# Local AI dataset paths
# ============================================================
WAREHOUSE_DATASET_ROOT=D:/warehouse_dataset
DATASET_CROPS_ROOT=D:/warehouse_dataset/dataset_crops
RAW_VIDEO_ROOT=D:/warehouse_dataset/raw_videos_full
REVIEW_CROP_ROOT=D:/warehouse_dataset/review_crops_reid_yoloseg
IMOU_SD_VIDEO_ROOT=D:/warehouse_dataset/raw_videos_from_imou_sd

# ============================================================
# YOLO
# ============================================================
YOLO_CONF=0.4
YOLO_IOU=0.5
YOLO_IMG_SIZE=640

# ============================================================
# Body Re-ID
# ============================================================
REID_FINETUNED_PATH=models/reid_resnet50_v3_cleanval.pth
REID_MATCH_THRESHOLD=0.93
REID_MATCH_MARGIN=0.015
REID_TOPK_MEAN=5

# ============================================================
# InsightFace hybrid signal
# ============================================================
FACE_MODEL_NAME=buffalo_l
FACE_DET_SIZE=640,640
FACE_DET_THRESH=0.35
FACE_MATCH_THRESHOLD=0.38
FACE_MATCH_MARGIN=0.09

# ============================================================
# RFID-trigger visual verify (Zone 1)
# ============================================================
# Threshold thấp hơn Zone 2 vì crop Zone 1 có thể góc nghiêng khi quẹt thẻ
RFID_VISUAL_MATCH_THRESHOLD=0.65
# Bỏ qua person trong buffer nếu cũ hơn số giây này
ZONE1_BEST_PERSON_MAX_AGE_SEC=2.0
# true = bắt buộc detect được face mới confirm; false = RFID + person presence là đủ khi không có face
ZONE1_FACE_REQUIRED=false

# ============================================================
# RFID/MQTT
# ============================================================
MQTT_BROKER=127.0.0.1
MQTT_PORT=1883
MQTT_TOPIC=warehouse/rfid/scan
MQTT_CLIENT=pc-warehouse-server

# ============================================================
# Dashboard
# ============================================================
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# ============================================================
# ntfy mobile alerts
# ============================================================
ENABLE_NTFY_ALERT=false
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=your_topic
NTFY_ALERT_DIR=outputs/ntfy_alerts
NTFY_COOLDOWN_SECONDS=5
