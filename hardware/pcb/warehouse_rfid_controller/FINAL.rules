    "/RFID_MISO" "unconnected-(J2-Pin_5-Pad5)" "/RFID_RST" "/BUZZER_NEG " "unconnected-(U1-Pin_1-Pad1)" "unconnected-(U1-Pin_3-Pad3)" "unconnected-(U1-Pin_5-Pad5)" "unconnected-(U1-Pin_6-Pad6)"
    "unconnected-(U1-Pin_7-Pad7)" "unconnected-(U1-Pin_8-Pad8)" "unconnected-(U1-Pin_9-Pad9)" "unconnected-(U1-Pin_11-Pad11)" "unconnected-(U1-Pin_13-Pad13)" "unconnected-(U1-Pin_16-Pad16)" "unconnected-(U1-Pin_18-Pad18)" "unconnected-(U1-Pin_20-Pad20)"
    "unconnected-(U1-Pin_21-Pad21)" "unconnected-(U1-Pin_22-Pad22)" "unconnected-(U1-Pin_23-Pad23)" "unconnected-(U1-Pin_24-Pad24)" "unconnected-(U1-Pin_26-Pad26)"
    (clearance_class "kicad_default")
